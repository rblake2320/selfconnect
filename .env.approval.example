# SelfConnect — Telegram Approval Bridge configuration
# Copy this file to .env.approval and fill in real values.

# 1. Create a bot: message @BotFather on Telegram -> /newbot -> copy token
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN

# 2. Your chat/channel ID.
#    Easiest: add @RawDataBot to your private channel, it will print the chat ID.
#    Or use a private group and get the ID from @getidsbot.
TELEGRAM_CHAT_ID=REPLACE_WITH_CHAT_ID

# 3. YOUR Telegram user ID (NOT the bot's ID).
#    Get it: message @userinfobot on Telegram — it replies with your numeric ID.
#    The bridge rejects all messages from anyone else.
TELEGRAM_ALLOWED_USER_ID=REPLACE_WITH_YOUR_NUMERIC_USER_ID

# Optional: scan interval in seconds (default 2.0)
# APPROVAL_POLL_INTERVAL=2.0
